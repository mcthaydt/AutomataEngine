{
  "name": "automata-engine-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "games/*",
    "tools/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "ci": "npm run lint && npm run typecheck && npm run test",
    "dev:monkey-ball": "npm run dev -w monkey-ball",
    "dev:editor": "npm run dev -w level-editor",
    "dev:pulsebreak": "npm run dev -w pulsebreak",
    "dev:last-lightkeeper": "npm run dev -w last-lightkeeper",
    "new-game": "node tools/scaffold/src/main.ts",
    "e2e": "playwright test",
    "e2e:last-lightkeeper": "PLAYWRIGHT_ONLY=last-lightkeeper playwright test e2e/last-lightkeeper.spec.ts",
    "preview:last-lightkeeper": "vite preview games/last-lightkeeper --host 127.0.0.1 --port 4177 --strictPort",
    "build": "npm run build --workspaces --if-present",
    "verify:new-game": "node tools/scaffold/scripts/verify-new-game.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "happy-dom": "^20.10.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
